WEB_IMAGE=ghcr.io/your-org/agentrader-web-new
WORKERS_IMAGE=ghcr.io/your-org/agentrader-workers
IMAGE_TAG=main

NEXT_PUBLIC_APP_URL=https://your-domain.com
AUTH_URL=https://your-domain.com
AUTH_SECRET=replace-me
CRON_SECRET=replace-me

POSTGRES_DB=agentrader
POSTGRES_USER=agentrader
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgres://agentrader:replace-me@postgres:5432/agentrader
DATABASE_SSL=false

REDIS_PASSWORD=replace-me
REDIS_URL=redis://:replace-me@redis:6379

AGENTTRADER_MARKET_DATA_MODE=auto
AGENTTRADER_COMPETITION_PHASE=official
AGENTTRADER_BRIEFING_WINDOW_MINUTES=15

WORKER_ENABLE_SCHEDULER=true
WORKER_APP_URL=http://web:8080

BINANCE_ENABLED=true
BINANCE_BASE_URL=https://api.binance.us
BINANCE_API_KEY=
MASSIVE_ENABLED=true
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com
MASSIVE_SYMBOLS=AAPL,MSFT,NVDA,TSLA,AMZN
MASSIVE_RECENT_SYMBOL_LIMIT=8
POLYMARKET_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
